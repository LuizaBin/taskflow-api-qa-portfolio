// ============================================================
// PLAYWRIGHT + TYPESCRIPT — OpenWeather API Test Suite
// Based on test cases: TC01–TC12
// Docs: https://openweathermap.org/api


import { test, expect, request } from "@playwright/test";

// CONFIGURATION
// Replace YOUR_API_KEY with your actual OpenWeather API key.


const BASE_URL = "https://api.openweathermap.org/data/2.5";
const API_KEY = process.env.API_KEY ?? "YOUR_API_KEY";


// TYPE DEFINITIONS
// Describes the shape of the OpenWeather API response.


type WeatherMain = {
  temp: number;
  feels_like: number;
  humidity: number;
  pressure: number;
};

type WeatherDescription = {
  id: number;
  main: string;
  description: string;
  icon: string;
};

type WeatherResponse = {
  name: string;
  main: WeatherMain;
  weather: WeatherDescription[];
  cod: number;
};

type ErrorResponse = {
  cod: string | number;
  message: string;
};


// TC01 — SMOKE TEST: Current weather for a valid city
// Type: Positive | Priority: High
// Checks the API is up and returns data for a real city


test("TC01 | Smoke | Current weather – valid city returns 200", async ({ request }) => {
  const response = await request.get(`${BASE_URL}/weather`, {
    params: { q: "London", appid: API_KEY },
  });

  // Status must be 200
  expect(response.status()).toBe(200);

  const body: WeatherResponse = await response.json();

  // Response must contain weather and main fields
  expect(body).toHaveProperty("weather");
  expect(body).toHaveProperty("main");

  // City name must match what we requested
  expect(body.name).toBe("London");
});

// TC02 — NEGATIVE: Invalid city name
// Type: Negative | Priority: High
// API should return 404 with a "city not found" message


test("TC02 | Negative | Invalid city returns 404", async ({ request }) => {
  const response = await request.get(`${BASE_URL}/weather`, {
    params: { q: "NoCityHere", appid: API_KEY },
  });

  expect(response.status()).toBe(404);

  const body: ErrorResponse = await response.json();

  // Error message should mention city not found
  expect(body.message.toLowerCase()).toContain("city not found");
});


// TC03 — NEGATIVE: Empty city parameter
// Type: Negative | Priority: High
// Sending an empty string should return 400 or 404


test("TC03 | Negative | Empty city returns 400 or 404", async ({ request }) => {
  const response = await request.get(`${BASE_URL}/weather`, {
    params: { q: "", appid: API_KEY },
  });

  // Accept either 400 or 404 — both are valid error responses
  expect([400, 404]).toContain(response.status());
});


