// TC06 — DATA VALIDATION: Temperature is a number
// Type: Positive | Priority: Medium
// This is like your Webz.io field type checks —
// make sure the data type returned is what we expect


test("TC06 | Data Validation | Temperature field is a number", async ({ request }) => {
  const response = await request.get(`${BASE_URL}/weather`, {
    params: { q: "London", appid: API_KEY },
  });

  expect(response.status()).toBe(200);

  const body: WeatherResponse = await response.json();

  // typeof will return "number" if it's a valid number
  expect(typeof body.main.temp).toBe("number");
});


// TC07 — DATA VALIDATION: Humidity is a number
// Type: Positive | Priority: Medium
// Same as TC06 but for the humidity field


test("TC07 | Data Validation | Humidity field is a number", async ({ request }) => {
  const response = await request.get(`${BASE_URL}/weather`, {
    params: { q: "London", appid: API_KEY },
  });

  expect(response.status()).toBe(200);

  const body: WeatherResponse = await response.json();

  expect(typeof body.main.humidity).toBe("number");

  // Humidity should logically be between 0 and 100
  expect(body.main.humidity).toBeGreaterThanOrEqual(0);
  expect(body.main.humidity).toBeLessThanOrEqual(100);
});


// TC08 — DATA VALIDATION: Weather array exists and is valid
// Type: Positive | Priority: Medium
// The weather field should be an array with at least one item


test("TC08 | Data Validation | Weather array exists and is not empty", async ({ request }) => {
  const response = await request.get(`${BASE_URL}/weather`, {
    params: { q: "London", appid: API_KEY },
  });

  const body: WeatherResponse = await response.json();

  // Must be an array
  expect(Array.isArray(body.weather)).toBe(true);

  // Must have at least one weather entry
  expect(body.weather.length).toBeGreaterThan(0);

  // Each entry should have a description field
  expect(body.weather[0]).toHaveProperty("description");
});

// TC09 — HEADER CHECK: Content-Type is application/json
// Type: Positive | Priority: Low
// Verifies the API is returning JSON, not HTML or plain text


test("TC09 | Header | Content-Type is application/json", async ({ request }) => {
  const response = await request.get(`${BASE_URL}/weather`, {
    params: { q: "London", appid: API_KEY },
  });

  // Get the content-type header value
  const contentType = response.headers()["content-type"];

  // Should contain application/json
  expect(contentType).toContain("application/json");
});


